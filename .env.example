# Colmena ByFlow — Variables de Entorno
# Copia este archivo a .env y configura tus keys

# Grok API (misma key que ByFlow)
GROK_API_KEY=
GROK_MODEL=grok-3-mini

# Alpha Vantage (free tier — opcional para GFlow)
ALPHA_VANTAGE_KEY=

# Simulación
EARNINGS_BASE_RATE=2.50

# Schedules (cron, vacío = deshabilitado)
SCHEDULE_GFLOW=
SCHEDULE_BOLITA=
SCHEDULE_ROBOT=
