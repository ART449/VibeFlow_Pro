<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pos_hub_root"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pos_hub_hero"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ByFlow POS"
                android:textColor="@color/pos_hub_orange"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Hub nativo para piso, caja y operacion"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="2dp"
                android:text="La web sigue viva debajo, pero desde aqui empezamos a reemplazar el POS por flujos Android reales."
                android:textColor="@color/pos_hub_subtle"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/pos_hub_status_line"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_pos_hub_chip"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:textColor="@android:color/white"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Flujos listos hoy"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/hub_btn_mesas"
                android:layout_width="0dp"
                android:layout_height="132dp"
                android:layout_weight="1"
                android:background="@drawable/bg_pos_hub_card"
                android:gravity="start|bottom"
                android:padding="18dp"
                android:text="Mesas y comanda"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/hub_btn_cocina"
                android:layout_width="0dp"
                android:layout_height="132dp"
                android:layout_weight="1"
                android:background="@drawable/bg_pos_hub_card_alt"
                android:gravity="start|bottom"
                android:padding="18dp"
                android:text="Monitor cocina"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/hub_btn_comandas"
                android:layout_width="0dp"
                android:layout_height="112dp"
                android:layout_weight="1"
                android:background="@drawable/bg_pos_hub_card_soft"
                android:gravity="start|bottom"
                android:padding="18dp"
                android:text="Comandas"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/hub_btn_inventario"
                android:layout_width="0dp"
                android:layout_height="112dp"
                android:layout_weight="1"
                android:background="@drawable/bg_pos_hub_card_soft"
                android:gravity="start|bottom"
                android:padding="18dp"
                android:text="Inventario"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/hub_btn_corte"
                android:layout_width="0dp"
                android:layout_height="112dp"
                android:layout_weight="1"
                android:background="@drawable/bg_pos_hub_card_soft"
                android:gravity="start|bottom"
                android:padding="18dp"
                android:text="Caja y corte"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/hub_btn_wrapper"
                android:layout_width="0dp"
                android:layout_height="112dp"
                android:layout_weight="1"
                android:background="@drawable/bg_pos_hub_primary_button"
                android:gravity="start|bottom"
                android:padding="18dp"
                android:text="ByFlow completo"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Siguiente paso recomendado"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_pos_hub_note"
            android:lineSpacingExtra="2dp"
            android:padding="16dp"
            android:text="Cobro nativo con estado de mesa, total en vivo, propina y acceso rapido a Tap to Pay."
            android:textColor="@color/pos_hub_text"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
