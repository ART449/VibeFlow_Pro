{
  "name": "vibeflow-pro",
  "version": "1.0.0",
  "description": "VibeFlow Pro - Teleprompter & Karaoke System",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest --verbose --forceExit",
    "cap:copy:android": "npx cap copy android",
    "cap:sync:android": "npx cap sync android",
    "cap:open:android": "npx cap open android",
    "android:doctor": "powershell -ExecutionPolicy Bypass -File .\\scripts\\android-build-debug.ps1 -DoctorOnly",
    "android:apk:debug": "powershell -ExecutionPolicy Bypass -File .\\scripts\\android-build-debug.ps1 -BuildType debug",
    "android:apk:release": "powershell -ExecutionPolicy Bypass -File .\\scripts\\android-build-debug.ps1 -BuildType release",
    "android:apk:bundled": "powershell -ExecutionPolicy Bypass -File .\\scripts\\android-build-debug.ps1 -BuildType debug -AppMode bundled",
    "android:install:debug": "powershell -ExecutionPolicy Bypass -File .\\scripts\\android-install-debug.ps1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.4",
    "sql.js": "^1.14.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}
